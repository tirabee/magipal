{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Magipal",
  "version": "0.9.1",
  "identifier": "io.github.tirabee.magipal",
  "build": {
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "npm run build",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Magipal",
        "width": 1200,
        "height": 800,
        "minWidth": 820,
        "minHeight": 560,
        "center": true,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": null,
      "assetProtocol": {
        "enable": true,
        "scope": ["**"]
      }
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "createUpdaterArtifacts": true,
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  },
  "plugins": {
    "updater": {
      "endpoints": [
        "https://github.com/tirabee/magipal/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEVGQTk3NjU2MzRBNUMyNDMKUldSRHdxVTBWbmFwN3hmMmJNbnRONEY4MFRYZTI0eGt4eTRBeU0wdkgwVzhRRFIveXZTVXk0RUgK"
    }
  }
}
